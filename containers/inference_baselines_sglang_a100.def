Bootstrap: docker
From: nvidia/cuda:12.9.1-cudnn-devel-ubuntu22.04

%post
    chmod 1777 /tmp
    export DEBIAN_FRONTEND=noninteractive
    export TMPDIR="/opt/tmp"
    export UV_CACHE_DIR="/opt/uv_cache"
    export UV_HTTP_TIMEOUT="600"
    export UV_LINK_MODE="copy"
    export PIP_CACHE_DIR="/opt/pip_cache"

    mkdir -p "${TMPDIR}" "${UV_CACHE_DIR}" "${PIP_CACHE_DIR}"

    apt-get update && apt-get install -y \
        python3.10 \
        python3-dev \
        python3-pip \
        python3-venv \
        git \
        wget \
        curl \
        build-essential \
        && rm -rf /var/lib/apt/lists/*

    ln -sf /usr/bin/python3.10 /usr/bin/python3
    ln -sf /usr/bin/python3.10 /usr/bin/python

    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
    apt-get install -y nodejs

    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    uv pip install --system --no-cache \
        --index-url https://download.pytorch.org/whl/cu128 \
        torch==2.8.0 \
        torchvision==0.23.0 \
        torchaudio==2.8.0

    # sglang[all] resolves its own sgl-kernel/flashinfer pins for the installed torch.
    uv pip install --system --no-cache --prerelease=allow "sglang[all]"

    npm install -g \
        @anthropic-ai/claude-code \
        @openai/codex \
        @google/gemini-cli

    uv pip install --system --no-cache ninja packaging wheel setuptools

    uv pip install --system --no-cache \
        accelerate \
        boto3 \
        datasets \
        openai \
        pandas \
        tokenizers \
        transformers \
        inspect-ai \
        tiktoken \
        certifi

    mkdir -p /opt
    cd /opt
    git clone https://github.com/rank-and-file/filelock_workarounds.git

%environment
    export PATH="/root/.local/bin:$PATH"
    export NO_PROXY="localhost,127.0.0.1"
    export no_proxy="localhost,127.0.0.1"
    export PYTHONPATH="/opt/filelock_workarounds/soft_file_locks:$PYTHONPATH"

%runscript
    exec python3 "$@"

%labels
    Version v1.0
    Description SGLang-based inference baseline container with CUDA support (cu128) + AI CLI tools

%help
    Note: Use the --nv flag to enable NVIDIA GPU support when running the container.
