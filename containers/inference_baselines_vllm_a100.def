Bootstrap: docker
From: nvidia/cuda:12.9.1-cudnn-devel-ubuntu22.04

%post
    chmod 1777 /tmp
    export DEBIAN_FRONTEND=noninteractive
    export TMPDIR="/opt/tmp"
    export UV_CACHE_DIR="/opt/uv_cache"
    export UV_HTTP_TIMEOUT="600"
    export UV_LINK_MODE="copy"
    export PIP_CACHE_DIR="/opt/pip_cache"

    mkdir -p "${TMPDIR}" "${UV_CACHE_DIR}" "${PIP_CACHE_DIR}"

    # Update and install system dependencies
    apt-get update && apt-get install -y \
        python3.10 \
        python3-dev \
        python3-pip \
        python3-venv \
        git \
        wget \
        curl \
        build-essential \
        && rm -rf /var/lib/apt/lists/*

    # Create python3 symlink
    ln -sf /usr/bin/python3.10 /usr/bin/python3
    ln -sf /usr/bin/python3.10 /usr/bin/python
    
    # Install Node.js (LTS version 22.x) for npm
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
    apt-get install -y nodejs
    
    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"
    
    # Ensure CUDA torch is installed (PyPI default may resolve to CPU-only torch).
    uv pip install --system --no-cache \
        --index-url https://download.pytorch.org/whl/cu128 \
        torch==2.8.0 \
        torchvision==0.23.0 \
        torchaudio==2.8.0

    # Install xformers from PyTorch index (vllm 0.11.0 requires 0.0.32.post1 which
    # only resolves from the cu128 wheel index, not vanilla PyPI).
    uv pip install --system --no-cache \
        --index-url https://download.pytorch.org/whl/cu128 \
        xformers==0.0.32.post1 || \
        echo "[inference_baselines_vllm.def] WARN: xformers 0.0.32.post1 install failed; trying latest."
    uv pip install --system --no-cache xformers 2>/dev/null || true

    uv pip install --system --no-cache --no-deps vllm==0.11.0
    uv pip install --system --no-cache vllm==0.11.0 --torch-backend=auto 2>/dev/null || true

    # flashinfer: PyPI package name is "flashinfer-python", not "flashinfer".
    # It depends on apache-tvm-ffi (a pre-release), so --prerelease=allow is needed.
    uv pip install --system --no-cache --prerelease=allow flashinfer-python || \
        echo "[inference_baselines_vllm.def] WARN: flashinfer-python install failed; continuing."
    
    # Install AI CLI tools via npm
    npm install -g \
        @anthropic-ai/claude-code \
        @openai/codex \
        @google/gemini-cli
    
    uv pip install --system --no-cache ninja packaging wheel setuptools
    
    # Install the required packages
    uv pip install --system --no-cache \
        accelerate \
        boto3 \
        bitsandbytes \
        datasets \
        evaluate \
        lm-eval \
        openai \
        pandas \
        scikit-learn \
        shortuuid \
        tokenizers \
        transformers \
        trl \
        peft \
        inspect-ai \
        tiktoken \
        matplotlib \
        certifi

    # flash-attn requires a CUDA-enabled torch + nvcc toolchain at build time.
    # On some build hosts, dependency resolution picks CPU torch, which makes
    # flash-attn fail hard and abort the entire container build.
    # Keep it best-effort so baseline image creation stays reliable.
    export CUDA_HOME="/usr/local/cuda"
    if command -v nvcc >/dev/null 2>&1 && python3 - <<'PY'
import torch
raise SystemExit(0 if getattr(torch.version, "cuda", None) else 1)
PY
    then
        uv pip install --system --no-cache flash_attn --no-build-isolation || \
            echo "[inference_baselines_vllm.def] WARN: flash_attn install failed; continuing."
    else
        echo "[inference_baselines_vllm.def] INFO: skipping flash_attn (no nvcc or CUDA torch)."
    fi
    
    # install inspect evals (best-effort: latest versions require Python>=3.11)
    mkdir -p /opt
    cd /opt
    git clone --depth=1 https://github.com/UKGovernmentBEIS/inspect_evals.git || true
    if [ -d /opt/inspect_evals ]; then
        cd /opt/inspect_evals
        uv pip install --system --no-cache . 2>/dev/null || \
            echo "[inference_baselines_vllm.def] WARN: inspect_evals install failed (needs Python>=3.11); skipping."
    fi

    cd /opt
    git clone https://github.com/rank-and-file/filelock_workarounds.git
    
%environment
    export PATH="/root/.local/bin:$PATH"
    export NO_PROXY="localhost,127.0.0.1"
    export no_proxy="localhost,127.0.0.1"
    export PYTHONPATH="/opt/filelock_workarounds/soft_file_locks:$PYTHONPATH"

%runscript
    exec python3 "$@"

%labels
    Version v1.0
    Description Python ML container with CUDA support for transformers and LLM training (using uv) + AI CLI tools

%help
    Note: Use the --nv flag to enable NVIDIA GPU support when running the container.
