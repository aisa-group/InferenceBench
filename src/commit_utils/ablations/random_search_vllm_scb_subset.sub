executable = /bin/bash
dataset_seed = 248
quality_seed = 248
mmlupro_n = 500
quality_concurrency = 1
base_model = mistralai/Mistral-7B-Instruct-v0.3
backends = vllm

arguments = src/baselines/run_precompute_all_baselines.sh $(base_model) $(Cluster) $(backends) $(dataset_seed) $(quality_seed) $(mmlupro_n) $(quality_concurrency)
# Sc.B subset rerun: test only 4 pre-selected configs (the existing a/c/d
# winners) rather than re-running all 36 configs. Driven by
# RANDOM_SEARCH_CONFIG_IDS; requires num-configs/search-seed to match the
# original so config IDs resolve to the same dict entries.
#   config 0  = vLLM DEFAULT
#   config 5  = Sc.C winner  (max-num-seqs=64, batched=2048, fp8 kv)
#   config 7  = Sc.A winner  (max-num-seqs=512, batched=16384, fp8 kv)
#   config 31 = Sc.D winner  (max-num-seqs=128, batched=16384, auto kv)
environment = "OPENAI_API_KEY=$ENV(OPENAI_API_KEY) ANTHROPIC_API_KEY=$ENV(ANTHROPIC_API_KEY) GEMINI_API_KEY=$ENV(GEMINI_API_KEY) KIMI_API_KEY=$ENV(KIMI_API_KEY) HOME=$ENV(HOME) INFERENCE_BENCH_RESULTS_DIR=$ENV(INFERENCE_BENCH_RESULTS_DIR) INFERENCE_BENCH_CONTAINERS_DIR=$ENV(INFERENCE_BENCH_CONTAINERS_DIR) INFERENCE_BENCH_CONTAINER_NAME=$ENV(INFERENCE_BENCH_CONTAINER_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_SGLANG_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_SGLANG_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_VLLM_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_VLLM_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_TORCH_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_TORCH_NAME) INFERENCE_BENCH_MAX_MODEL_LEN=$ENV(INFERENCE_BENCH_MAX_MODEL_LEN) INFERENCE_BENCH_VENV_HOST=$ENV(INFERENCE_BENCH_VENV_HOST) INFERENCE_BENCH_VENV_SGLANG_HOST=$ENV(INFERENCE_BENCH_VENV_SGLANG_HOST) INFERENCE_BENCH_VENV_VLLM_HOST=$ENV(INFERENCE_BENCH_VENV_VLLM_HOST) INFERENCE_BENCH_VENV_TORCH_HOST=$ENV(INFERENCE_BENCH_VENV_TORCH_HOST) INFERENCE_BENCH_USE_SPLIT_BACKEND_ENVS=$ENV(INFERENCE_BENCH_USE_SPLIT_BACKEND_ENVS) INFERENCE_BENCH_CONTINUE_ON_BACKEND_ERROR=$ENV(INFERENCE_BENCH_CONTINUE_ON_BACKEND_ERROR) INFERENCE_BENCH_SERVER_START_TIMEOUT_S=$ENV(INFERENCE_BENCH_SERVER_START_TIMEOUT_S) INFERENCE_BENCH_SGLANG_SERVER_START_TIMEOUT_S=$ENV(INFERENCE_BENCH_SGLANG_SERVER_START_TIMEOUT_S) INFERENCE_BENCH_DEBUG_STACK_DUMP=$ENV(INFERENCE_BENCH_DEBUG_STACK_DUMP) INFERENCE_BENCH_SKIP_SPEED=$ENV(INFERENCE_BENCH_SKIP_SPEED) INFERENCE_BENCH_SKIP_QUALITY=$ENV(INFERENCE_BENCH_SKIP_QUALITY) HF_HOME=$ENV(HF_HOME) HF_TOKEN=$ENV(HF_TOKEN) HF_HUB_CACHE=$ENV(HF_HUB_CACHE) TRANSFORMERS_CACHE=$ENV(TRANSFORMERS_CACHE) HUGGINGFACE_HUB_CACHE=$ENV(HUGGINGFACE_HUB_CACHE) HF_HUB_OFFLINE=$ENV(HF_HUB_OFFLINE) INFERENCE_BENCH_DOWNLOAD_ONLY=$ENV(INFERENCE_BENCH_DOWNLOAD_ONLY) HF_HUB_DISABLE_XET=$ENV(HF_HUB_DISABLE_XET) INFERENCE_BENCH_INNER_MODE=random_search_b RANDOM_SEARCH_OUT_ROOT=/fast/$ENV(USER)/random_search_vllm RANDOM_SEARCH_EVAL_TIMEOUT=7200 RANDOM_SEARCH_N=32 RANDOM_SEARCH_SEED=248 RANDOM_SEARCH_CONFIG_IDS=0,5,7,31"
error = random_search_vllm_scb_subset_$(Cluster).err
output = random_search_vllm_scb_subset_$(Cluster).out
log = random_search_vllm_scb_subset_$(Cluster).log
request_memory = 180000
request_cpus = 16
request_gpus = 1
requirements = TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3"
request_disk = 400G
+BypassLXCfs = "true"

stream_output = true
stream_error = true

queue
