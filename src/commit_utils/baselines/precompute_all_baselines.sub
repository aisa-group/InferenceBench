executable = /bin/bash
dataset_seed = 248
quality_seed = 248
mmlupro_n = 500
quality_concurrency = 16
base_model = mistralai/Mistral-7B-Instruct-v0.3
backends = vllm,torch

arguments = src/baselines/run_precompute_all_baselines.sh $(base_model) $(Cluster) $(backends) $(dataset_seed) $(quality_seed) $(mmlupro_n) $(quality_concurrency)
environment = "OPENAI_API_KEY=$ENV(OPENAI_API_KEY) ANTHROPIC_API_KEY=$ENV(ANTHROPIC_API_KEY) GEMINI_API_KEY=$ENV(GEMINI_API_KEY) KIMI_API_KEY=$ENV(KIMI_API_KEY) HOME=$ENV(HOME) INFERENCE_BENCH_RESULTS_DIR=$ENV(INFERENCE_BENCH_RESULTS_DIR) INFERENCE_BENCH_CONTAINERS_DIR=$ENV(INFERENCE_BENCH_CONTAINERS_DIR) INFERENCE_BENCH_CONTAINER_NAME=$ENV(INFERENCE_BENCH_CONTAINER_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_SGLANG_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_SGLANG_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_VLLM_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_VLLM_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_TORCH_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_TORCH_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_TGI_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_TGI_NAME) INFERENCE_BENCH_MAX_MODEL_LEN=$ENV(INFERENCE_BENCH_MAX_MODEL_LEN) INFERENCE_BENCH_VENV_HOST=$ENV(INFERENCE_BENCH_VENV_HOST) INFERENCE_BENCH_VENV_SGLANG_HOST=$ENV(INFERENCE_BENCH_VENV_SGLANG_HOST) INFERENCE_BENCH_VENV_VLLM_HOST=$ENV(INFERENCE_BENCH_VENV_VLLM_HOST) INFERENCE_BENCH_VENV_TORCH_HOST=$ENV(INFERENCE_BENCH_VENV_TORCH_HOST) INFERENCE_BENCH_VENV_TGI_HOST=$ENV(INFERENCE_BENCH_VENV_TGI_HOST) INFERENCE_BENCH_USE_SPLIT_BACKEND_ENVS=$ENV(INFERENCE_BENCH_USE_SPLIT_BACKEND_ENVS) INFERENCE_BENCH_CONTINUE_ON_BACKEND_ERROR=$ENV(INFERENCE_BENCH_CONTINUE_ON_BACKEND_ERROR) INFERENCE_BENCH_SERVER_START_TIMEOUT_S=$ENV(INFERENCE_BENCH_SERVER_START_TIMEOUT_S) INFERENCE_BENCH_DEBUG_STACK_DUMP=$ENV(INFERENCE_BENCH_DEBUG_STACK_DUMP) INFERENCE_BENCH_SKIP_SPEED=$ENV(INFERENCE_BENCH_SKIP_SPEED) INFERENCE_BENCH_SKIP_QUALITY=$ENV(INFERENCE_BENCH_SKIP_QUALITY) HF_HOME=$ENV(HF_HOME) HF_TOKEN=$ENV(HF_TOKEN) HF_HUB_CACHE=$ENV(HF_HUB_CACHE) TRANSFORMERS_CACHE=$ENV(TRANSFORMERS_CACHE) HUGGINGFACE_HUB_CACHE=$ENV(HUGGINGFACE_HUB_CACHE) HF_HUB_OFFLINE=$ENV(HF_HUB_OFFLINE) INFERENCE_BENCH_DOWNLOAD_ONLY=$ENV(INFERENCE_BENCH_DOWNLOAD_ONLY) HF_HUB_DISABLE_XET=$ENV(HF_HUB_DISABLE_XET)"
error = baseline_precompute_$(Cluster).err
output = baseline_precompute_$(Cluster).out
log = baseline_precompute_$(Cluster).log
# This job frequently spikes above 128GB RSS during model init/compilation.
# Some clusters enforce a ~0.9x safety factor on the requested memory limit,
# so request extra headroom to avoid getting held mid-run.
request_memory = 180000
request_cpus = 16
request_gpus = 1
requirements = TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3"
request_disk=400G
+BypassLXCfs="true"

# Make stdout/stderr visible while the job is running (not only after completion/hold).
stream_output = true
stream_error = true

# Defaults (override via `condor_submit_bid ... -a key=value`):
# -a base_model=mistralai/Mistral-7B-Instruct-v0.3
# -a backends=vllm,torch,sglang,tgi
# -a dataset_seed=248
# -a quality_seed=248
# -a mmlu_n=128
# -a gsm8k_n=128
# -a quality_concurrency=4
queue
