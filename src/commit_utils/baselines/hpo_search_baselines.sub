executable = /bin/bash

method = random
engine = vllm
scenario = a
seed_id = 0
seed_dev = 21
seed_eval = 1337
quality_seed = 248
mmlupro_n = 500
quality_concurrency = 4
budget_s = 7200
quick_eval_timeout_s = 180
server_start_timeout_s = 300
first_server_start_timeout_s = 360
server_initial_delay_s = 60
base_model = mistralai/Mistral-7B-Instruct-v0.3
backends = $(engine)

arguments = src/baselines/run_precompute_all_baselines.sh $(base_model) $(Cluster) $(backends) $(seed_dev) $(quality_seed) $(mmlupro_n) $(quality_concurrency)
environment = "OPENAI_API_KEY=$ENV(OPENAI_API_KEY) ANTHROPIC_API_KEY=$ENV(ANTHROPIC_API_KEY) GEMINI_API_KEY=$ENV(GEMINI_API_KEY) KIMI_API_KEY=$ENV(KIMI_API_KEY) HOME=$ENV(HOME) INFERENCE_BENCH_RESULTS_DIR=$ENV(INFERENCE_BENCH_RESULTS_DIR) INFERENCE_BENCH_CONTAINERS_DIR=$ENV(INFERENCE_BENCH_CONTAINERS_DIR) INFERENCE_BENCH_CONTAINER_NAME=$ENV(INFERENCE_BENCH_CONTAINER_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_SGLANG_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_SGLANG_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_VLLM_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_VLLM_NAME) INFERENCE_BENCH_BASELINE_CONTAINER_TGI_NAME=$ENV(INFERENCE_BENCH_BASELINE_CONTAINER_TGI_NAME) INFERENCE_BENCH_MAX_MODEL_LEN=$ENV(INFERENCE_BENCH_MAX_MODEL_LEN) INFERENCE_BENCH_VENV_HOST=$ENV(INFERENCE_BENCH_VENV_HOST) INFERENCE_BENCH_VENV_SGLANG_HOST=$ENV(INFERENCE_BENCH_VENV_SGLANG_HOST) INFERENCE_BENCH_VENV_VLLM_HOST=$ENV(INFERENCE_BENCH_VENV_VLLM_HOST) INFERENCE_BENCH_VENV_TGI_HOST=$ENV(INFERENCE_BENCH_VENV_TGI_HOST) INFERENCE_BENCH_USE_SPLIT_BACKEND_ENVS=$ENV(INFERENCE_BENCH_USE_SPLIT_BACKEND_ENVS) INFERENCE_BENCH_SERVER_START_TIMEOUT_S=$ENV(INFERENCE_BENCH_SERVER_START_TIMEOUT_S) INFERENCE_BENCH_DEBUG_STACK_DUMP=$ENV(INFERENCE_BENCH_DEBUG_STACK_DUMP) HF_HOME=$ENV(HF_HOME) HF_TOKEN=$ENV(HF_TOKEN) HF_HUB_CACHE=$ENV(HF_HUB_CACHE) TRANSFORMERS_CACHE=$ENV(TRANSFORMERS_CACHE) HUGGINGFACE_HUB_CACHE=$ENV(HUGGINGFACE_HUB_CACHE) HF_HUB_OFFLINE=$ENV(HF_HUB_OFFLINE) HF_HUB_DISABLE_XET=$ENV(HF_HUB_DISABLE_XET) INFERENCE_BENCH_INNER_MODE=hpo_search HPO_BASELINE_METHOD=$(method) HPO_BASELINE_ENGINE=$(engine) HPO_BASELINE_SCENARIO=$(scenario) HPO_BASELINE_SEED_ID=$(seed_id) HPO_BASELINE_SEED_DEV=$(seed_dev) HPO_BASELINE_SEED_EVAL=$(seed_eval) HPO_BASELINE_QUALITY_SEED=$(quality_seed) HPO_BASELINE_BUDGET_S=$(budget_s) HPO_BASELINE_QUICK_EVAL_TIMEOUT_S=$(quick_eval_timeout_s) HPO_BASELINE_SERVER_START_TIMEOUT_S=$(server_start_timeout_s) HPO_BASELINE_FIRST_SERVER_START_TIMEOUT_S=$(first_server_start_timeout_s) HPO_BASELINE_SERVER_INITIAL_DELAY_S=$(server_initial_delay_s) HPO_BASELINE_OUT_ROOT=$ENV(HPO_BASELINE_OUT_ROOT) HPO_BASELINE_AUTO_INSTALL_DEPS=$ENV(HPO_BASELINE_AUTO_INSTALL_DEPS) HPO_BASELINE_OVERWRITE=$ENV(HPO_BASELINE_OVERWRITE) HPO_BASELINE_MAX_TRIALS=$ENV(HPO_BASELINE_MAX_TRIALS) HPO_BASELINE_ALLOW_UNSAFE_SEARCH_SPACE=$ENV(HPO_BASELINE_ALLOW_UNSAFE_SEARCH_SPACE)"

error = hpo_search_$(method)_$(engine)_$(scenario)_$(Cluster).err
output = hpo_search_$(method)_$(engine)_$(scenario)_$(Cluster).out
log = hpo_search_$(method)_$(engine)_$(scenario)_$(Cluster).log

request_memory = 180000
request_cpus = 16
request_gpus = 1
requirements = TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3"
request_disk = 400G
+BypassLXCfs = "true"

stream_output = true
stream_error = true

queue
