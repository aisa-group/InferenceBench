executable = /bin/bash
arguments = src/run_task.sh $(eval) $(agent) $(base_model) $(Cluster) $(num_hours) $(agent_config) $(starting_point) $(agent_seed) $(eval_seed)
environment = "OPENAI_API_KEY=$ENV(OPENAI_API_KEY) ANTHROPIC_API_KEY=$ENV(ANTHROPIC_API_KEY) GEMINI_API_KEY=$ENV(GEMINI_API_KEY) KIMI_API_KEY=$ENV(KIMI_API_KEY) HOME=$ENV(HOME) INFERENCE_BENCH_RESULTS_DIR=$ENV(INFERENCE_BENCH_RESULTS_DIR) INFERENCE_BENCH_CONTAINERS_DIR=$ENV(INFERENCE_BENCH_CONTAINERS_DIR) INFERENCE_BENCH_CONTAINER_NAME=$ENV(INFERENCE_BENCH_CONTAINER_NAME) INFERENCE_BENCH_JOB_SCHEDULER=$ENV(INFERENCE_BENCH_JOB_SCHEDULER) INFERENCE_BENCH_EXPERIMENT_NAME=$ENV(INFERENCE_BENCH_EXPERIMENT_NAME) INFERENCE_BENCH_PROMPT=$ENV(INFERENCE_BENCH_PROMPT) INFERENCE_BENCH_BASE_MODEL=$ENV(INFERENCE_BENCH_BASE_MODEL) INFERENCE_BENCH_QUALITY_TAU=$ENV(INFERENCE_BENCH_QUALITY_TAU) INFERENCE_BENCH_QUALITY_SEED=$ENV(INFERENCE_BENCH_QUALITY_SEED) INFERENCE_BENCH_QUALITY_MMLUPRO_N=$ENV(INFERENCE_BENCH_QUALITY_MMLUPRO_N) INFERENCE_BENCH_QUALITY_CONCURRENCY=$ENV(INFERENCE_BENCH_QUALITY_CONCURRENCY) INFERENCE_BENCH_QUALITY_BASELINE_REGISTRY=$ENV(INFERENCE_BENCH_QUALITY_BASELINE_REGISTRY) INFERENCE_BENCH_BASELINE_SERVER_URL=$ENV(INFERENCE_BENCH_BASELINE_SERVER_URL) HF_HOME=$ENV(HF_HOME) HF_TOKEN=$ENV(HF_TOKEN) HF_HUB_CACHE=$ENV(HF_HUB_CACHE) TRANSFORMERS_CACHE=$ENV(TRANSFORMERS_CACHE) HUGGINGFACE_HUB_CACHE=$ENV(HUGGINGFACE_HUB_CACHE) HF_HUB_OFFLINE=$ENV(HF_HUB_OFFLINE) INFERENCE_BENCH_STARTING_POINT=$ENV(INFERENCE_BENCH_STARTING_POINT) INFERENCE_BENCH_MAX_MODEL_LEN=$ENV(INFERENCE_BENCH_MAX_MODEL_LEN)"

request_memory = 180000
request_cpus = 16
request_gpus = 1
requirements = (TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3")
request_disk=400G
+BypassLXCfs="true"
on_exit_hold = (ExitCode == 85)
on_exit_hold_reason = "Job checkpointed for resume; will retry"
on_exit_hold_subcode = 99
periodic_release = ((HoldReasonCode == 34) && (NumSystemHolds < 3)) || ((HoldReasonCode == 3) && (HoldReasonSubCode == 99) && (NumSystemHolds < 5))
queue
